# 宝青坊 - 环境变量配置模板
# 复制此文件为 .env 并填入你的真实配置

# DeepSeek AI API Key（必填）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== STT 语音识别配置（五选一） ==========

# 【推荐】本地 Whisper - 无需API，完全免费
# pip install openai-whisper
# 无需配置，默认使用

# 方案2: OpenAI Whisper API（需梯子）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 方案3: 阿里云语音识别（国内）
# ALIYUN_ACCESS_KEY_ID=your_key
# ALIYUN_ACCESS_KEY_SECRET=your_secret
# ALIYUN_NLS_APP_KEY=your_app_key

# 方案4: 腾讯云语音识别（国内）
# TENCENT_SECRET_ID=your_id
# TENCENT_SECRET_KEY=your_key

# 方案5: 讯飞语音识别（需额外实现）
# XFYUN_APP_ID=your_id
# XFYUN_API_KEY=your_key
# XFYUN_API_SECRET=your_secret

# 火山引擎 TTS（可选，不填则使用浏览器TTS降级）
# 获取地址：https://www.volcengine.com/
VOLC_TTS_APPID=
VOLC_TTS_TOKEN=

# 服务器端口（可选）
HTTP_PORT=8080
WS_PORT=8765

# ═══════════════════════════════════════════
#  AI Agent 工具配置（Aider + CrewAI）
# ═══════════════════════════════════════════

# Claude 4 / Anthropic API Key（架构师 Agent 用，最强推理）
# 获取地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key（GPT-4o / GPT-4o-mini，前端/测试 Agent 用）
# 获取地址：https://platform.openai.com/
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里云百炼 / 通义千问（可选，国内替代方案）
# 获取地址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 火山引擎 / Doubao（可选，国内替代方案）
# 获取地址：https://console.volcengine.com/
ARK_API_KEY=xxxxxxxx-xxxxxxxx-xxxxxxxx-xxxxxxxx
