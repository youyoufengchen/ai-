  "_action_type_reference": {
    "animation": "普通骨骼动画（绝大多数动作）",
    "transformation": "变身序列：触发形态切换+特效+音效，不是单纯骨骼动画",
    "expression_gesture": "表情手势：肢体动作+同步表情（如撒娇摇头+娇嗔表情）",
    "special_skill": "特殊技能：含道具挂载/粒子特效/骨骼绑定特效的复合动作",
