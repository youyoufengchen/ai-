{
  "_comment": "Actor注册表 — 场景中所有可调度实体的定义。每个Actor有自己的骨骼类型、能力集、形态列表和音效集。",
  "version": "1.1",

  "_task_assignment_rules": {
    "_comment": "AI action_planner 在规划任务时的Actor选择逻辑（不是随机，是能力+语境推断）",
    "algorithm": "capability_match_then_context_prefer",
    "steps": [
      "1. 解析NPC台词意图 → 得到任务类型（FETCH/PRESENT/NAVIGATE/SUMMON等）",
      "2. 查询任务所需的capabilities列表",
      "3. 筛选场景中当前available的actor（已注册且未busy）",
      "4. 从满足能力的actor中，按context_weight最高者优先分配",
      "5. 若无任何actor满足，则NPC台词播报'暂时无法完成'并跳过该任务步骤"
    ],
    "task_capability_map": {
      "FETCH_PRODUCT":   ["LOCOMOTION", "MANIPULATION"],
      "PRESENT_PRODUCT": ["MANIPULATION"],
      "NAVIGATE_TO":     ["LOCOMOTION", "NAVIGATION"],
      "SUMMON_ACTOR":    ["SPAWNING"],
      "TRANSFORM":       ["TRANSFORMATION"],
      "EXPRESS_EMOTION": ["EXPRESSION"]
    }
  },

  "_capability_reference": {
    "_comment": "所有可用能力类型（在各actor的capabilities[]中引用）",
    "LOCOMOTION":      "移动能力：走路、跑步、飞行",
    "MANIPULATION":    "操作能力：抓取、放下、递送、展示",
    "EXPRESSION":      "表情能力：面部情绪表达",
    "TRANSFORMATION":  "变身能力：切换形态",
    "SPAWNING":        "召唤能力：生成其他Actor或道具",
    "NAVIGATION":      "导航能力：自主路径规划（可无人监督移动）",
    "INTERACTION":     "场景交互能力：开门、推抽屉、按按钮",
    "FLYING":          "飞行能力：可在空中自由移动",
    "GAZE_CONTROL":    "视线控制：头部朝向跟随目标"
  },

  "actors": [

